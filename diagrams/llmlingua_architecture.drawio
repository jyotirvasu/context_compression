        </mxCell>
        <mxCell id="insight-content" parent="1" style="text;html=1;align=left;fontSize=9;verticalAlign=top;" value="Higher perplexity = less predictable&#xa;= carries more unique information&#xa;= should be PRESERVED&#xa;&#xa;Low perplexity = redundant/obvious&#xa;= safe to REMOVE" vertex="1">
          <mxGeometry height="80" width="190" x="895" y="170" as="geometry" />
