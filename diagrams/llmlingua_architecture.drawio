        <mxCell id="arr-b-c-label" parent="1" style="text;html=1;align=left;fontSize=8;fontColor=#333333;" value="RankedContext[]&#xa;(selected contexts)" vertex="1">
          <mxGeometry height="25" width="110" x="345" y="520" as="geometry" />
        </mxCell>
        <mxCell id="arr-c-d" edge="1" parent="1" source="stageC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.7;" target="stageD">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
