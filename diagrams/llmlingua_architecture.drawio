        <mxCell id="legend-title" parent="1" style="text;html=1;align=center;fontSize=10;fontColor=#333333;" value="&lt;b&gt;Compression Granularity&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="180" x="900" y="535" as="geometry" />
        </mxCell>
        <mxCell id="legend-1" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#6c8ebf;" value="▓▓▓ Context-Level (Stage B)&#xa;      Select/remove entire documents" vertex="1">
