          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-a-b-label" parent="1" style="text;html=1;align=left;fontSize=8;fontColor=#333333;" value="BudgetAllocation&#xa;(per-context budgets)" vertex="1">
          <mxGeometry height="25" width="120" x="345" y="320" as="geometry" />
        </mxCell>
        <mxCell id="arr-b-c" edge="1" parent="1" source="stageB" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="stageC">
          <mxGeometry relative="1" as="geometry" />
