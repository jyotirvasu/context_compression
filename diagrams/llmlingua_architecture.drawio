        <mxCell id="arr-e-out" edge="1" parent="1" source="stageE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=1;exitY=0.4;entryX=0;entryY=0.5;" target="output">
          <mxGeometry relative="1" as="geometry" />
