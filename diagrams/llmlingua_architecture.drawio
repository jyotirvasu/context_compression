          <mxGeometry height="25" width="70" x="450" y="590" as="geometry" />
        </mxCell>
        <mxCell id="arr-d-e" edge="1" parent="1" source="stageD" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;exitX=1;exitY=0.3;entryX=0;entryY=0.4;" target="stageE">
          <mxGeometry relative="1" as="geometry" />
