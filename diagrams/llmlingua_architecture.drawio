          <mxGeometry height="30" width="195" x="895" y="595" as="geometry" />
        </mxCell>
        <mxCell id="legend-3" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#b85450;" value="▓▓▓ Token-Level (Stage D)&#xa;      Prune individual tokens by NLL" vertex="1">
          <mxGeometry height="30" width="195" x="895" y="630" as="geometry" />
        </mxCell>
        <mxCell id="legend-4" parent="1" style="text;html=1;align=center;fontSize=9;fontStyle=3;fontColor=#333333;" value="Coarse ──────────────→ Fine" vertex="1">
