          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-lm-b" edge="1" parent="1" source="small-lm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=1;dashed=1;exitX=0;exitY=0.3;entryX=0.3;entryY=1;" target="stageC">
          <mxGeometry relative="1" as="geometry">
