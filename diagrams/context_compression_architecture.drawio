        <mxCell id="e5" value="compressed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="stageD" target="stageE" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="packed context" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="stageE" target="output" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="guides retrieval" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;dashed=1;strokeColor=#d6b656;" edge="1" source="query" target="stageC" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LLM box -->
        <mxCell id="llm" value="LLM&#xa;(GPT-4 / Claude)" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="500" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="feed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="output" target="llm" parent="1">
