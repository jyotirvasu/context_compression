        </mxCell>

        <!-- Key insight box -->
        <mxCell id="insight" value="KEY PAPERS&#xa;─────────────────────────────&#xa;Stage D: Li et al. &quot;Compressing Context&#xa;to Enhance Inference Efficiency&quot; (EMNLP 2023)&#xa;→ Self-information filtering via GPT-2&#xa;&#xa;Stage E: Liu et al. &quot;Lost in the Middle&quot;&#xa;(TACL 2023)&#xa;→ LLMs attend to edges, not middle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
