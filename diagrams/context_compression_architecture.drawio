        </mxCell>

        <!-- Stats box -->
        <mxCell id="stats" value="Pipeline Stats (Demo Run)&#xa;─────────────────────&#xa;Original:   320 tokens&#xa;Compressed: 141 tokens&#xa;Ratio:      55.9% saved&#xa;Chunks:     5 → 5 → 5 → 5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="130" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- Config box -->
        <mxCell id="config" value="config.yaml" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontStyle=2;" vertex="1" parent="1">
